const express = require('express');
const cors = require('cors');
const bodyParser = require('body-parser');
const bcrypt = require('bcryptjs');
const jwt = require('jsonwebtoken');
const db = require('./db');

const app = express();
const PORT = 3000;
const SECRET_KEY = 'pollmind-secret-key-change-in-production';

// Middleware
app.use(cors());
app.use(bodyParser.json());
app.use(express.static('public'));

// Middleware d'authentification
const authenticateToken = (req, res, next) => {
  const authHeader = req.headers['authorization'];
  const token = authHeader && authHeader.split(' ')[1];

  if (!token) {
    return res.status(401).json({ error: 'Token manquant' });
  }

  jwt.verify(token, SECRET_KEY, (err, user) => {
    if (err) {
      return res.status(403).json({ error: 'Token invalide' });
    }
    req.user = user;
    next();
  });
};

// Middleware admin
const requireAdmin = (req, res, next) => {
  if (!req.user.is_admin) {
    return res.status(403).json({ error: 'Accès réservé aux administrateurs' });
  }
  next();
};

// ========== ROUTES AUTHENTIFICATION ==========

// Inscription
app.post('/api/register', async (req, res) => {
  const { username, password } = req.body;

  if (!username || !password) {
    return res.status(400).json({ error: 'Username et password requis' });
  }

  try {
    const hashedPassword = await bcrypt.hash(password, 10);
    
    const result = db.prepare('INSERT INTO users (username, password) VALUES (?, ?)')
      .run(username, hashedPassword);
      
    res.json({ 
      message: 'Inscription réussie',
      userId: result.lastInsertRowid
    });
  } catch (error) {
    if (error.message.includes('UNIQUE')) {
      return res.status(400).json({ error: 'Nom d\'utilisateur déjà pris' });
    }
    res.status(500).json({ error: 'Erreur lors de l\'inscription' });
  }
});

// Connexion
app.post('/api/login', async (req, res) => {
  const { username, password } = req.body;

  try {
    const user = db.prepare('SELECT * FROM users WHERE username = ?').get(username);

    if (!user) {
      return res.status(401).json({ error: 'Identifiants incorrects' });
    }

    const validPassword = await bcrypt.compare(password, user.password);
    
    if (!validPassword) {
      return res.status(401).json({ error: 'Identifiants incorrects' });
    }

    const token = jwt.sign(
      { 
        id: user.id, 
        username: user.username, 
        is_admin: user.is_admin 
      },
      SECRET_KEY,
      { expiresIn: '24h' }
    );

    res.json({
      token,
      user: {
        id: user.id,
        username: user.username,
        is_admin: user.is_admin,
        points: user.points
      }
    });
  } catch (error) {
    res.status(500).json({ error: 'Erreur serveur' });
  }
});

// Profil utilisateur
app.get('/api/profile', authenticateToken, (req, res) => {
  try {
    const user = db.prepare('SELECT id, username, is_admin, points FROM users WHERE id = ?')
      .get(req.user.id);
    res.json(user);
  } catch (error) {
    res.status(500).json({ error: 'Erreur serveur' });
  }
});

// ========== ROUTES QUESTIONS ==========

// Créer une question (admin seulement)
app.post('/api/questions', authenticateToken, requireAdmin, (req, res) => {
  const { title, description, options } = req.body;

  if (!title || !options || options.length < 2) {
    return res.status(400).json({ error: 'Titre et au moins 2 options requis' });
  }

  try {
    const result = db.prepare('INSERT INTO questions (title, description, created_by) VALUES (?, ?, ?)')
      .run(title, description, req.user.id);

    const questionId = result.lastInsertRowid;

    const stmt = db.prepare('INSERT INTO options (question_id, text) VALUES (?, ?)');
    
    options.forEach(option => {
      stmt.run(questionId, option.text);
    });

    res.json({ 
      message: 'Question créée avec succès',
      questionId
    });
  } catch (error) {
    res.status(500).json({ error: 'Erreur création question' });
  }
});

// Lister toutes les questions
app.get('/api/questions', authenticateToken, (req, res) => {
  try {
    const questions = db.prepare(`
      SELECT q.*, u.username as creator_name 
      FROM questions q 
      JOIN users u ON q.created_by = u.id 
      ORDER BY q.created_at DESC
    `).all();

    const questionsWithDetails = questions.map(q => {
      const options = db.prepare('SELECT * FROM options WHERE question_id = ?').all(q.id);

      const optionsWithStats = options.map(opt => {
        const stats = db.prepare(
          'SELECT SUM(shares) as total_shares, COUNT(*) as bet_count FROM bets WHERE option_id = ?'
        ).get(opt.id);

        return {
          ...opt,
          total_shares: stats.total_shares || 0,
          bet_count: stats.bet_count || 0
        };
      });

      return { ...q, options: optionsWithStats };
    });

    res.json(questionsWithDetails);
  } catch (error) {
    res.status(500).json({ error: 'Erreur serveur' });
  }
});

// Détails d'une question
app.get('/api/questions/:id', authenticateToken, (req, res) => {
  const questionId = req.params.id;

  try {
    const question = db.prepare('SELECT * FROM questions WHERE id = ?').get(questionId);

    if (!question) {
      return res.status(404).json({ error: 'Question non trouvée' });
    }

    const options = db.prepare('SELECT * FROM options WHERE question_id = ?').all(questionId);

    res.json({ ...question, options });
  } catch (error) {
    res.status(500).json({ error: 'Erreur serveur' });
  }
});

// Résoudre une question (admin seulement)
app.post('/api/questions/:id/resolve', authenticateToken, requireAdmin, (req, res) => {
  const { optionId } = req.body;
  const questionId = req.params.id;

  try {
    db.prepare(
      'UPDATE questions SET status = ?, resolution = ?, resolved_at = CURRENT_TIMESTAMP WHERE id = ?'
    ).run('resolved', optionId, questionId);

    db.prepare('UPDATE options SET is_correct = 1 WHERE id = ?').run(optionId);

    // Redistribuer les gains aux gagnants
    distributeWinnings(questionId, optionId);

    res.json({ message: 'Question résolue' });
  } catch (error) {
    res.status(500).json({ error: 'Erreur résolution question' });
  }
});

// Fonction pour redistribuer les gains
function distributeWinnings(questionId, correctOptionId) {
  try {
    const winningBets = db.prepare(
      'SELECT user_id, shares FROM bets WHERE question_id = ? AND option_id = ?'
    ).all(questionId, correctOptionId);

    if (winningBets.length === 0) return;

    const poolData = db.prepare(
      'SELECT SUM(amount) as total_pool FROM bets WHERE question_id = ?'
    ).get(questionId);

    const totalPool = poolData.total_pool || 0;
    const totalWinningShares = winningBets.reduce((sum, bet) => sum + bet.shares, 0);

    const updateStmt = db.prepare('UPDATE users SET points = points + ? WHERE id = ?');

    winningBets.forEach(bet => {
      const winnings = (bet.shares / totalWinningShares) * totalPool;
      updateStmt.run(winnings, bet.user_id);
    });
  } catch (error) {
    console.error('Erreur distribution gains:', error);
  }
}

// ========== ROUTES PARIS ==========

// Calculer le prix actuel d'une option (Automated Market Maker simplifié)
function calculatePrice(totalShares) {
  const basePrice = 0.5;
  const priceImpact = totalShares * 0.01; // 1% par share
  return Math.min(0.95, Math.max(0.05, basePrice + priceImpact));
}

// Placer un pari
app.post('/api/bets', authenticateToken, (req, res) => {
  const { questionId, optionId, amount } = req.body;

  if (!questionId || !optionId || !amount || amount <= 0) {
    return res.status(400).json({ error: 'Données invalides' });
  }

  try {
    // Vérifier que la question est ouverte
    const question = db.prepare('SELECT status FROM questions WHERE id = ?').get(questionId);
    
    if (!question || question.status !== 'open') {
      return res.status(400).json({ error: 'Question fermée ou inexistante' });
    }

    // Vérifier les points de l'utilisateur
    const user = db.prepare('SELECT points FROM users WHERE id = ?').get(req.user.id);
    
    if (user.points < amount) {
      return res.status(400).json({ error: 'Points insuffisants' });
    }

    // Calculer le prix et les shares
    const stats = db.prepare(
      'SELECT SUM(shares) as total_shares FROM bets WHERE option_id = ?'
    ).get(optionId);

    const currentTotalShares = stats.total_shares || 0;
    const price = calculatePrice(currentTotalShares);
    const shares = amount / price;

    // Débiter les points
    db.prepare('UPDATE users SET points = points - ? WHERE id = ?')
      .run(amount, req.user.id);

    // Enregistrer le pari
    const result = db.prepare(
      'INSERT INTO bets (user_id, question_id, option_id, amount, price, shares) VALUES (?, ?, ?, ?, ?, ?)'
    ).run(req.user.id, questionId, optionId, amount, price, shares);

    res.json({
      message: 'Pari enregistré',
      betId: result.lastInsertRowid,
      shares,
      price
    });
  } catch (error) {
    console.error('Erreur pari:', error);
    res.status(500).json({ error: 'Erreur enregistrement pari' });
  }
});

// Historique des paris de l'utilisateur
app.get('/api/my-bets', authenticateToken, (req, res) => {
  try {
    const bets = db.prepare(`
      SELECT b.*, q.title as question_title, o.text as option_text, q.status as question_status
      FROM bets b
      JOIN questions q ON b.question_id = q.id
      JOIN options o ON b.option_id = o.id
      WHERE b.user_id = ?
      ORDER BY b.created_at DESC
    `).all(req.user.id);

    res.json(bets);
  } catch (error) {
    res.status(500).json({ error: 'Erreur serveur' });
  }
});

// Leaderboard
app.get('/api/leaderboard', authenticateToken, (req, res) => {
  try {
    const users = db.prepare(
      'SELECT id, username, points FROM users WHERE is_admin = 0 ORDER BY points DESC LIMIT 10'
    ).all();

    res.json(users);
  } catch (error) {
    res.status(500).json({ error: 'Erreur serveur' });
  }
});

// ========== DÉMARRAGE SERVEUR ==========

app.listen(PORT, () => {
  console.log(`🚀 Serveur PollMind démarré sur http://localhost:${PORT}`);
});
